# URL Shortener Backend Environment Variables
# Copy this to .env and fill in your actual values

# PostgreSQL Database (Neon)
# Get this from your Neon dashboard: https://neon.tech/
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=postgresql://username:password@ep-xxx-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Redis Cache
# For local development: redis://localhost:6379
# For Render/production: redis://red-xxx:6379 (get from Render dashboard)
REDIS_URL=redis://localhost:6379

# Application Settings
ENVIRONMENT=development
DEBUG=True

# Optional: Custom domain for short URLs
# If deploying to custom domain, update this
BASE_URL=http://localhost:8000

# Security (for future OAuth implementation)
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
